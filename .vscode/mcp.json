{
  "servers": {
    "medcure-knowledge-graph": {
      "type": "stdio",
      "command": "py",
      "args": ["${workspaceFolder}/backend/knowledge-graph/mcp_server.py"],
      "env": {
        "KG_API_URL": "http://localhost:8000"
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "playwright-mcp",
      "args": ["--browser", "chromium", "--base-url", "http://localhost:3000"]
    }
  }
}

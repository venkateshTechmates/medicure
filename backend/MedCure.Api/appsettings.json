{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=medcure.db"
  },
  "Jwt": {
    "Issuer": "medcure",
    "Audience": "medcure-web",
    "Secret": "dev-secret-change-in-production-1234567890abcdef0987654321xyzabc",
    "ExpiresHours": 8
  },
  "KnowledgeGraph": {
    "BaseUrl": "http://localhost:8000"
  },
  "Otel": {
    "ServiceName": "medcure-api",
    "ServiceVersion": "1.0.0",
    "Sources": [ "medcure.*" ],
    "Exporters": {
      "Console": {
        "EnabledInDevelopment": true
      },
      "Otlp": {
        "EndpointEnvVar": "OTEL_EXPORTER_OTLP_ENDPOINT"
      }
    },
    "Instrumentation": {
      "AspNetCore": true,
      "HttpClient": true,
      "EntityFrameworkCore": true,
      "Runtime": true,
      "Process": true
    }
  }
}
